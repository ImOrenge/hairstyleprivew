7 verbose title npm exec tsx -e import { createClient } from '@supabase/supabase-js'; import { buildCatalogRowsForCycle, buildKoreanWeeklyStyleQueries } from './lib/hairstyle-catalog-seed.ts'; import { collectKoreanHairstyleTrendResearch } from './lib/hairstyle-trend-research.ts'; const supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL, process.env.SUPABASE_SERVICE_ROLE_KEY, { auth: { autoRefreshToken: false, persistSession: false } }); const nowIso = new Date().toISOString(); const run = async () => { let sourceMode = 'researched-weekly'; let research; try { research = await collectKoreanHairstyleTrendResearch(new Date(nowIso)); } catch (error) { sourceMode = 'seeded-weekly'; research = { trendSignals: new Map(), sourceSummary: { mode: 'seeded-weekly', queries: buildKoreanWeeklyStyleQueries(new Date(nowIso)), notes: 'Weekly Korean hairstyle catalog rebuilt from curated seed blueprints without live research.', providers: ['catalog-seed'], documentsCollected: 0, documentsUsed: 0 } }; console.warn('[catalog-bootstrap] researched rebuild failed, using seeded fallback:', error instanceof Error ? error.message : String(error)); } const cycleInsert = await supabase.from('hairstyle_catalog_cycles').insert({ status: 'running', market: 'kr', started_at: nowIso, item_count: 0, source_summary: research.sourceSummary }).select('cycle_id').single(); if (cycleInsert.error || !cycleInsert.data?.cycle_id) throw new Error(cycleInsert.error?.message || 'Failed to create cycle'); const cycleId = cycleInsert.data.cycle_id; const rows = buildCatalogRowsForCycle(cycleId, nowIso, research.trendSignals); const slugs = rows.map((row) => row.slug); const existing = await supabase.from('hairstyle_catalog').select('slug').in('slug', slugs); if (existing.error) throw new Error(existing.error.message); const existingSlugs = new Set((existing.data || []).map((row) => typeof row.slug === 'string' ? row.slug : '').filter(Boolean)); const payload = rows.map((row) => ({ slug: row.slug, name_ko: row.nameKo, description: row.description, market: row.market, length_bucket: row.lengthBucket, silhouette: row.silhouette, texture: row.texture, bang_type: row.bangType, volume_focus_tags: row.volumeFocusTags, face_shape_fit_tags: row.faceShapeFitTags, avoid_tags: row.avoidTags, trend_score: row.trendScore, freshness_score: row.freshnessScore, prompt_template: row.promptTemplate, negative_prompt: row.negativePrompt, prompt_template_version: row.promptTemplateVersion, status: row.status, source_cycle_id: row.sourceCycleId })); const upsert = await supabase.from('hairstyle_catalog').upsert(payload, { onConflict: 'slug' }); if (upsert.error) throw new Error(upsert.error.message); const finish = await supabase.from('hairstyle_catalog_cycles').update({ status: 'succeeded', finished_at: new Date().toISOString(), item_count: payload.length, error_log: null, source_summary: research.sourceSummary }).eq('cycle_id', cycleId); if (finish.error) throw new Error(finish.error.message); console.log(JSON.stringify({ cycleId, itemCount: payload.length, insertedCount: payload.filter((row) => !existingSlugs.has(row.slug)).length, updatedCount: payload.filter((row) => existingSlugs.has(row.slug)).length, resolvedMode: sourceMode }, null, 2)); }; run().catch(async (error) => { console.error(error); process.exit(1); });
