{
  "expo": {
    "name": "HairFit",
    "slug": "hairfit-app",
    "scheme": "hairfit",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.hairfit.app",
      "associatedDomains": [
        "applinks:hairfit.beauty"
      ]
    },
    "android": {
      "package": "com.hairfit.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hairfit.beauty",
              "pathPrefix": "/generate/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "@portone/react-native-sdk/plugin",
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseUrl": "https://hairfit.beauty",
      "router": {
        "origin": false
      }
    }
  }
}
