NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding?account_type=member&return_url=%2Fmypage
# Protected-page Playwright only. Use an existing development-instance test user.
# A +clerk_test address prevents verification and new-device emails from being delivered.
E2E_CLERK_USER_EMAIL=e2e+clerk_test@example.com
E2E_CLERK_ADMIN_EMAIL=e2e-admin+clerk_test@example.com
E2E_CLERK_SALON_EMAIL=e2e-salon+clerk_test@example.com
# Read-only protected E2E: this existing completed generation must belong to E2E_CLERK_USER_EMAIL.
E2E_OWNED_GENERATION_ID=
# Read-only protected E2E: another +clerk_test account must own this existing generation.
E2E_FOREIGN_GENERATION_ID=
E2E_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=YOUR_E2E_SUPABASE_SERVICE_ROLE_KEY
EXPO_PUBLIC_API_BASE_URL=https://hairfit.beauty

# Optional server-only live Clerk key for production-only landing social proof in non-production environments.
# Must start with sk_live_. Test keys are ignored for the landing user count.
CLERK_SOCIAL_PROOF_SECRET_KEY=

# Local development only: comma-separated Clerk user IDs that should behave as salon_owner.
DEV_CLERK_SALON_USER_IDS=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

NEXT_PUBLIC_PORTONE_V2_STORE_ID=YOUR_PORTONE_STORE_ID
NEXT_PUBLIC_PORTONE_V2_CHANNEL_KEY=YOUR_PORTONE_CHANNEL_KEY
PORTONE_V2_STORE_ID=YOUR_PORTONE_STORE_ID
PORTONE_V2_CHANNEL_KEY=YOUR_PORTONE_CHANNEL_KEY
PORTONE_V2_API_SECRET=YOUR_PORTONE_API_SECRET
PORTONE_V2_WEBHOOK_SECRET=YOUR_PORTONE_WEBHOOK_SECRET
BILLING_KEY_ENCRYPTION_SECRET=YOUR_32_BYTE_OR_LONGER_SECRET
# Fail-closed rollout switch. Keep false until lot backfill and shadow decisions reconcile.
REFUND_AUTOMATION_ENABLED=false
# Shared bearer secret for refund execution and notification outbox drain endpoints.
PORTONE_REFUND_WORKER_SECRET=YOUR_32_BYTE_OR_LONGER_RANDOM_SECRET

# Google Play Billing stays fail-closed until Play Console, RTDN, and internal-track purchases are verified.
GOOGLE_PLAY_BILLING_ENABLED=false
GOOGLE_PLAY_PACKAGE_NAME=com.hairfit.app
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=YOUR_PLAY_SERVICE_ACCOUNT_EMAIL
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_PLAY_TOKEN_ENCRYPTION_SECRET=YOUR_SEPARATE_32_BYTE_OR_LONGER_RANDOM_SECRET
GOOGLE_PLAY_PUBSUB_AUDIENCE=https://hairfit.beauty/api/payments/google-play/rtdn
GOOGLE_PLAY_PUBSUB_PUSH_SERVICE_ACCOUNT_EMAIL=YOUR_PUBSUB_PUSH_SERVICE_ACCOUNT_EMAIL

INTERNAL_API_SECRET=YOUR_INTERNAL_API_SECRET
# Placeholder values are rejected at runtime. Generate at least 32 random bytes and store the same value as a Worker secret.
GENERATION_WORKFLOW_CALLBACK_SECRET=YOUR_32_BYTE_OR_LONGER_RANDOM_SECRET
# Domain-separated SHA-256 fingerprint of the callback secret. App and Workflow must use the same value.
GENERATION_WORKFLOW_CALLBACK_SECRET_FINGERPRINT=YOUR_64_CHARACTER_LOWERCASE_HEX_FINGERPRINT
# Next.js 개발 서버에서만 Supabase outbox를 서버 측 로컬 실행기로 소비합니다.
# 프로덕션은 항상 Cloudflare Workflow binding을 사용합니다.
HAIRFIT_LOCAL_GENERATION_WORKFLOW=enabled
# Production rollout switches. Set false to stop only new acceptance while
# accepted/generating work, status reads, refunds, and notification drains continue.
GENERATION_ACCEPTANCE_ENABLED=true
STYLING_ACCEPTANCE_ENABLED=true
# Required server-only HMAC key for five-minute paid-action quotes. Keep this
# separate from Workflow and Supabase credentials; there is no credential fallback.
PAID_ACTION_QUOTE_SECRET=YOUR_32_BYTE_OR_LONGER_RANDOM_SECRET
# Quotes are fail-closed by default. Set false only as a short-lived rollback
# switch for an explicitly monitored legacy-client compatibility window.
PAID_ACTION_QUOTES_REQUIRED=true
# Public app-link association identifiers. Do not use debug signing values in production.
HAIRFIT_APPLE_TEAM_ID=
HAIRFIT_ANDROID_CERT_SHA256=
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=HairFit <noreply@hairfit.beauty>
# Optional operations thresholds. Defaults are 15 and 5 minutes when omitted.
GENERATION_NOTIFICATION_QUEUE_AGE_WARNING_MINUTES=15
GENERATION_NOTIFICATION_RETRY_OVERDUE_WARNING_MINUTES=5
GENERATION_PUSH_ENABLED=false
EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN
INBOUND_EMAIL_SECRET=YOUR_RANDOM_SHARED_SECRET
NTS_BUSINESS_SERVICE_KEY=YOUR_DATA_GO_KR_SERVICE_KEY

GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_VISION_MODEL=gpt-5.4-mini
PROMPT_LLM_MODEL=gemini-2.5-pro
PROMPT_RESEARCH_MODEL=gemini-2.5-pro
PROMPT_DEEP_RESEARCH_GROUNDING=true
AFTERCARE_LLM_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image

# Pricing economics and packs (optional). Paid-action unit costs are fixed in
# packages/shared/src/billing/policy-selectors.ts and are not env-configurable.
PRICING_STYLE_COST_USD=0.16
PRICING_TARGET_MARGIN=0.4
PRICING_USD_TO_KRW=1350
PRICING_SAFETY_MULTIPLIER=1.06
PRICING_FREE_CREDITS=10
PRICING_FREE_PRICE_KRW=0
PRICING_BASIC_CREDITS=80
PRICING_BASIC_PRICE_KRW=9900
PRICING_STANDARD_CREDITS=200
PRICING_STANDARD_PRICE_KRW=19900
PRICING_PRO_CREDITS=600
PRICING_PRO_PRICE_KRW=49900
PRICING_SALON_CREDITS=500
PRICING_SALON_PRICE_KRW=39900
