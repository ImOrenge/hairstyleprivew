{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "hairfit-email-router",
  "main": "src/index.ts",
  "workers_dev": false,
  "preview_urls": false,
  "compatibility_date": "2026-02-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_INBOUND_EMAIL_URL": "https://hairfit.beauty/api/email/inbound/cloudflare"
  }
}
